  },
  "devDependencies": {
    "@mariozechner/pi-agent-core": "^0.54.0",
    "@types/node": "^25.3.0",
    "bun-types": "^1.3.9",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
