{
  "name": "pi-dcp",
  "version": "1.0.0",
  "description": "Dynamic Context Pruning (DCP) extension for the Pi Coding Agent",
  "type": "module",
  "scripts": {
    "test": "bun test",
    "format": "prettier --write \"**/*.{ts,md,json,jsonc}\"",
